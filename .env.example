# Example env vars for the Sleep Tight dashboard + tracking endpoints.
# Copy to .env.local for local development; set the real values in
# Vercel → Project Settings → Environment Variables for production.
# All values below are EXAMPLES — replace with your own.

# --- Auth ---
DASHBOARD_PASSWORD=change-me-to-a-long-random-string

# --- Meta Ads ---
META_AD_ACCOUNT_ID=act_0000000000000000
META_ACCESS_TOKEN=replace-with-ads_read-token

# --- Meta Pixel ---
# Pixel ID from Meta Events Manager. Non-sensitive (it ships to the browser
# anyway) but kept in env so Preview/local-dev can stay clean by leaving it
# unset — /api/pixel.js returns an empty body when this is missing.
# Digits only. The value below is a placeholder.
META_PIXEL_ID=0000000000000000

# --- MailerLite ---
MAILERLITE_API_TOKEN=replace-with-mailerlite-token
MAILERLITE_FREE_EBOOK_GROUP_ID=0000000000
MAILERLITE_PAID_BUNDLE_GROUP_ID=0000000000

# --- Timezones (both required — no silent fallbacks) ---
# IANA timezone names only. The example values here reflect the original
# Sleep Tight setup; change them to whatever your operation runs in.
DASHBOARD_TIMEZONE=America/Bogota
META_AD_ACCOUNT_TIMEZONE=America/Los_Angeles

# --- Analytics backend ---
REDIS_URL=redis://default:password@host:6379

# --- Analytics hygiene ---
# Comma-separated visitor_ids whose events should be dropped at ingest
# (populated via /admin/my-visitor-id.html for your own devices).
INTERNAL_VISITOR_IDS=

# --- Guide download ---
# Where /api/download-pdf 302s to. Used by the email-survey thank-you
# page's "Download Sleep Tight" button (and any other surfaces that
# want a stable redirect URL). Use a Google Drive direct-download
# link, an S3 signed URL, or any HTTPS host. If unset, /api/download-pdf
# returns 503 with a setup-hint message.
SLEEP_TIGHT_DOWNLOAD_URL=https://drive.google.com/uc?export=download&id=REPLACE_WITH_FILE_ID
